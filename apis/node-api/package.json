{
  "name": "@fx/node-api",
  "version": "0.0.1",
  "private": true,
  "description": "Fastify modular monolith — Phase 1 shell (BE-010…015) + DB schema (Step 1.4)",
  "type": "module",
  "scripts": {
    "dev": "prisma generate && tsx watch src/server.ts",
    "worker:market-data": "tsx watch src/workers/main.ts",
    "prebuild": "prisma generate",
    "build": "tsup src/server.ts src/workers/main.ts --format esm --clean",
    "start": "node dist/server.js",
    "start:worker:market-data": "node dist/workers/main.js",
    "openapi": "tsx scripts/openapi.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:timescale": "tsx scripts/apply-timescale.ts",
    "predb:seed": "prisma generate",
    "db:seed": "prisma db seed",
    "db:seed-creds": "tsx scripts/seed-broker-credentials.ts",
    "db:studio": "prisma studio",
    "pretypecheck": "prisma generate",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "pretest": "prisma generate",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/websocket": "^11.2.0",
    "@fx/types": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bullmq": "^5.34.0",
    "fastify": "^5.9.0",
    "fastify-type-provider-zod": "^7.0.0",
    "ioredis": "^5.4.1",
    "pg": "^8.16.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@fx/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.15.0",
    "@types/ws": "^8.18.1",
    "prisma": "^7.8.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.5",
    "vitest": "^4.1.9"
  }
}
