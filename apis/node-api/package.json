{
  "name": "@fx/node-api",
  "version": "0.0.1",
  "private": true,
  "description": "Fastify modular monolith \u2014 Phase 1 shell (BE-010\u2026015) + DB schema (Step 1.4)",
  "type": "module",
  "scripts": {
    "dev": "prisma generate && tsx watch src/server.ts",
    "worker:market-data": "tsx watch src/workers/main.ts",
    "worker:execution": "tsx watch src/workers/execution-main.ts",
    "worker:signals": "tsx watch src/workers/signals-main.ts",
    "worker:supervision": "tsx watch src/workers/supervision-main.ts",
    "worker:backtests": "tsx watch src/workers/backtests-main.ts",
    "enqueue-intent": "tsx scripts/enqueue-intent.ts",
    "trip-signals": "tsx scripts/trip-signals.ts",
    "backtest:agentic": "tsx scripts/run-agentic-backtest.ts",
    "prebuild": "prisma generate",
    "build": "tsup src/server.ts src/workers/main.ts src/workers/execution-main.ts src/workers/signals-main.ts src/workers/supervision-main.ts src/workers/backtests-main.ts src/otel.ts --format esm --clean",
    "start": "node --import ./dist/otel.js dist/server.js",
    "start:worker:market-data": "node --import ./dist/otel.js dist/workers/main.js",
    "start:worker:execution": "node --import ./dist/otel.js dist/workers/execution-main.js",
    "start:worker:signals": "node --import ./dist/otel.js dist/workers/signals-main.js",
    "start:worker:supervision": "node --import ./dist/otel.js dist/workers/supervision-main.js",
    "start:worker:backtests": "node --import ./dist/otel.js dist/workers/backtests-main.js",
    "openapi": "tsx scripts/openapi.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:timescale": "tsx scripts/apply-timescale.ts",
    "predb:seed": "prisma generate",
    "db:seed": "prisma db seed",
    "db:seed-creds": "tsx scripts/seed-broker-credentials.ts",
    "db:studio": "prisma studio",
    "pretypecheck": "prisma generate",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "pretest": "prisma generate",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/websocket": "^11.2.0",
    "@fx/llm": "workspace:*",
    "@fx/risk-gate": "workspace:*",
    "@fx/types": "workspace:*",
    "@grpc/grpc-js": "^1.12.6",
    "@grpc/proto-loader": "^0.7.13",
    "@langchain/core": "^1.2.2",
    "@langchain/langgraph": "^1.4.7",
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/auto-instrumentations-node": "^0.56.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/instrumentation": "^7.8.0",
    "bullmq": "^5.34.0",
    "bullmq-otel": "^1.0.1",
    "fastify": "^5.9.0",
    "fastify-type-provider-zod": "^7.0.0",
    "ioredis": "^5.4.1",
    "jose": "^6.2.3",
    "otpauth": "^9.4.0",
    "pg": "^8.16.0",
    "resend": "^6.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@fx/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.15.0",
    "@types/ws": "^8.18.1",
    "prisma": "^7.8.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.5",
    "vitest": "^4.1.9"
  }
}
