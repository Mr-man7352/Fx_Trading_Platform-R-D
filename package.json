{
  "name": "fx-trading-platform",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "node scripts/check-env.mjs && turbo run dev",
    "build": "turbo run build",
    "check-env": "node scripts/check-env.mjs",
    "openapi": "pnpm --filter @fx/node-api openapi",
    "db:generate": "pnpm --filter @fx/node-api db:generate",
    "db:migrate": "pnpm --filter @fx/node-api db:migrate",
    "db:deploy": "pnpm --filter @fx/node-api db:deploy",
    "db:timescale": "pnpm --filter @fx/node-api db:timescale",
    "seed:dev": "pnpm --filter @fx/node-api db:seed",
    "seed:creds": "pnpm --filter @fx/node-api db:seed-creds",
    "check-migrations": "node scripts/check-migrations.mjs",
    "stack:uep": "docker compose -f infra/docker-compose.local.yml up -d --build",
    "stack:down": "docker compose -f infra/docker-compose.local.yml down",
    "stack:ps": "docker compose -f infra/docker-compose.local.yml ps",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "turbo": "^2.10.2",
    "typescript": "~5.9.3"
  }
}
