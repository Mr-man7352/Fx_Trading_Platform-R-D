  },
  "dependencies": {
    "@fx/types": "workspace:*"
  },
  "devDependencies": {
    "@fx/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.9"
  }
}
