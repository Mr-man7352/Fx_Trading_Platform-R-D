{
  "name": "@fx/llm",
  "version": "0.0.1",
  "private": true,
  "description": "LLM provider factory + failover (BE-060) and prompt registry + model snapshot pinning (BE-061)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
