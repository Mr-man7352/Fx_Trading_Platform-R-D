# --- Global ---
NODE_ENV=development

# --- Trading mode (BE-003): backtest | paper | live ---
TRADING_MODE=paper

# --- Node API (BE-002) ---
API_PORT=4000
LOG_LEVEL=info

# --- Node API — Fastify shell (BE-011/013) ---
# Phase 1 auth stand-in (BE-013): >=16 chars; sent as `x-internal-token` header
# (or `?token=` on /ws). Replaced by NextAuth JWT (BE-030) in Phase 5.
INTERNAL_API_TOKEN=dev-internal-token-change-me
# Comma-separated CORS allowlist (BE-011).
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Max requests per IP per minute (BE-011).
RATE_LIMIT_MAX=100

# --- Local stack (BE-004) — dev-only defaults; never reuse in prod ---
POSTGRES_USER=fx
POSTGRES_PASSWORD=fx_dev_password
POSTGRES_DB=fx
DATABASE_URL=postgresql://fx:fx_dev_password@localhost:5432/fx
REDIS_URL=redis://localhost:6379
# 5001, not 5000 — macOS AirPlay Receiver squats on 5000.
QUANT_PORT=5001
QUANT_URL=http://localhost:5001
# Quant gRPC plane (QN-001) — Pipeline/SizePosition/Predict + health RPC.
QUANT_GRPC_PORT=50051

# --- Broker credential sealing (BE-131) ---
# base64 of exactly 32 random bytes: `openssl rand -base64 32`.
# Dev-only default below; generate a fresh key for anything real. Losing the
# prod key orphans every sealed credential (rotation bumps key_version).
CREDENTIALS_ENCRYPTION_KEY=ZGV2LW9ubHktY3JlZGVudGlhbHMta2V5LTMyYnl0ZXM=
# Only needed for `pnpm seed:creds` (CLI-seeded OANDA creds until Phase 5):
# OANDA_API_TOKEN=your-oanda-v20-personal-access-token
# OANDA_ACCOUNT_ID=101-004-1234567-001

# --- Build metadata (injected in CI; optional locally) ---
# GIT_COMMIT=abc1234
