# --- Global ---
NODE_ENV=development

# --- Trading mode (BE-003): backtest | paper | live ---
TRADING_MODE=paper

# --- Node API (BE-002) ---
API_PORT=4000
LOG_LEVEL=info

# --- Node API — Fastify shell (BE-011/013) ---
# Phase 1 auth stand-in (BE-013): >=16 chars; sent as `x-internal-token` header
# (or `?token=` on /ws). Replaced by NextAuth JWT (BE-030) in Phase 5.
INTERNAL_API_TOKEN=dev-internal-token-change-me
# Comma-separated CORS allowlist (BE-011).
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Max requests per IP per minute (BE-011).
RATE_LIMIT_MAX=100

# --- Local stack (BE-004) — dev-only defaults; never reuse in prod ---
POSTGRES_USER=fx
POSTGRES_PASSWORD=fx_dev_password
POSTGRES_DB=fx
DATABASE_URL=postgresql://fx:fx_dev_password@localhost:5432/fx
REDIS_URL=redis://localhost:6379
# 5001, not 5000 — macOS AirPlay Receiver squats on 5000.
QUANT_PORT=5001
QUANT_URL=http://localhost:5001
# Quant gRPC plane (QN-001) — Pipeline/SizePosition/Predict + health RPC.
QUANT_GRPC_PORT=50051
# BE-050 — ExecutionService client address (Node workers → quant gRPC).
QUANT_GRPC_URL=localhost:50051

# --- BE-050/051/052 execution & reconciliation (Step 2.2) ---
# Mismatch action: halt | flatten_and_halt (default halt).
RECONCILE_ACTION=halt
TRADE_MANAGER_PARTIAL_TRIGGER_R=1
TRADE_MANAGER_PARTIAL_FRACTION=0.5
TRADE_MANAGER_BREAKEVEN_BUFFER_R=0.05
TRADE_MANAGER_TRAIL_DISTANCE_R=0.5
# Optional Telegram alerts for fills/halts/reconciliation (no-op when unset).
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZ
ELEGRAM_CHAT_ID=my-telegram-chat-id

# --- Broker credential sealing (BE-131) ---
# base64 of exactly 32 random bytes: `openssl rand -base64 32`.
# Dev-only default below; generate a fresh key for anything real. Losing the
# prod key orphans every sealed credential (rotation bumps key_version).
CREDENTIALS_ENCRYPTION_KEY=ZGV2LW9ubHktY3JlZGVudGlhbHMta2V5LTMyYnl0ZXM=
# Only needed for `pnpm seed:creds` (CLI-seeded OANDA creds until Phase 5):
OANDA_API_TOKEN=real-oanda-token-goes-here
OANDA_ACCOUNT_ID=real-oanda-account-id-goes-here

# --- Step 1.6 market-data providers (all OPTIONAL; mock-first without them) ---
# OANDA streaming + candle backfill (QN-020/QN-021/BE-041). practice | live.
OANDA_ENVIRONMENT=practice
# Twelve Data free-tier cross-check key (QN-021/BE-041): https://twelvedata.com
# TWELVE_DATA_API_KEY=your-twelve-data-key
# Macro ingest keys (BE-043). FRED: https://fred.stlouisfed.org  EIA: https://eia.gov
FRED_API_KEY=replace-with-your-fred-key
EIA_API_KEY=replace-with-your-eia-key
# Comma-separated OANDA instruments to stream/backfill (QN-020/021).
# MARKET_INSTRUMENTS=EUR_USD,GBP_USD,USD_JPY,XAU_USD,WTICO_USD,BCO_USD
# Backfill window (months) + base candle granularity (QN-021).
BACKFILL_MONTHS=6
BACKFILL_GRANULARITY=H1
# Redis list/stream name the market-data ingest CLI publishes ticks to.
# MARKET_TICKS_QUEUE=market-ticks
# FinBERT model id for news sentiment (QN-022); requires the `ml` dep-group.
# FINBERT_MODEL=ProsusAI/finbert
# Vendored @fx/types JSON Schemas dir; only needed if resolving outside the
# quant service's default location (services/quant/app/contracts/schemas).
# FX_CONTRACTS_DIR=/path/to/schemas

# --- Step 2.3 deterministic quant core (QN-040…048) — all OPTIONAL ---
# Sizing (QN-042/044). RISK_PER_TRADE_PCT is clamped to the 1% hard ceiling
# in code regardless of this value (system design §10).
# ACCOUNT_CURRENCY=GBP
# RISK_PER_TRADE_PCT=0.01
# VOL_RISK_PCT=0.005
# KELLY_FRACTION=0.25
# PROB_SIZING_ENABLED=false
# MIN_RR=1.8
# Pipeline lookback + label horizon (bars) and the model artifact directory.
# PIPELINE_LOOKBACK_BARS=500
# LABEL_HORIZON_BARS=24
# MODEL_DIR=/path/to/services/quant/var/models
# Correlation clustering (QN-048) — defaults match system design §10.
# CORR_LOOKBACK_DAYS=60
# CORR_THRESHOLD=0.7
# CORR_REFRESH_DAYS=7
# CORR_EVENT_LOOKBACK_DAYS=20
# CORR_VOL_SPIKE_MULT=2.0

# --- Observability (BE-140/141) — all OPTIONAL; unset ⇒ tracing off ---
# OTLP/HTTP collector endpoint (Tempo). Local: pnpm stack:up + the
# `observability` compose profile serves it on http://localhost:4318
# (in-network: http://tempo:4318). Applies to node-api, worker, and quant.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Grafana admin password for the local observability profile (dev default).
GRAFANA_ADMIN_PASSWORD=admin

# --- Backups (BE-142) — used by infra/backup/*.sh on the DB host, not the app ---
# RESTIC_REPOSITORY=s3:https://<endpoint>/<bucket>/fx-db
# RESTIC_PASSWORD=generate-with-openssl-rand-base64-32
# AWS_ACCESS_KEY_ID=s3-compatible-key
# AWS_SECRET_ACCESS_KEY=s3-compatible-secret

# --- Build metadata (injected in CI; optional locally) ---
# GIT_COMMIT=abc1234
