{
  "title": "BrokerPosition",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "instrument": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,6}_[A-Z0-9]{2,6}$"
    },
    "side": {
      "type": "string",
      "enum": ["buy", "sell"]
    },
    "units": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "avgPrice": {
      "type": "number"
    },
    "unrealizedPl": {
      "type": "number"
    },
    "brokerTradeIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["instrument", "side", "units", "avgPrice", "unrealizedPl", "brokerTradeIds"],
  "additionalProperties": false
}
